# POST /api/campaign/run runs a zero-cost MOCK pipeline by default.
# To run the REAL Anthropic agent chain, set both of these:

# Opt-in flag for live agents. Leave unset/false to keep the free mock demo.
# USE_LIVE_AGENT=true

# Anthropic API key — required only when USE_LIVE_AGENT=true.
# Get one at https://console.anthropic.com/settings/keys
# Copy this file to `.env.local` and fill it in. (.env.local is gitignored.)
ANTHROPIC_API_KEY=

# Optional: override the model the campaign agents run on.
# Defaults to claude-sonnet-4-6 if unset.
# METALYDE_AGENT_MODEL=claude-sonnet-4-6
